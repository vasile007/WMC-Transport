{
  "info": {
    "name": "QuikMove API",
    "description": "Postman collection generated from openapi.yaml for QuikMove backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "0.1.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "orderId", "value": "1", "type": "string" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-inject Authorization: Bearer {{token}} unless public/webhook",
          "const token = pm.variables.get('token');",
          "const method = pm.request.method;",
          "let path = '';",
          "try { path = pm.request.url.getPath(); } catch (e) {",
          "  try { path = '/' + ((pm.request.url && pm.request.url.path) ? pm.request.url.path.join('/') : ''); } catch (e2) { path = ''; }",
          "}",
          "const isPublic = (method === 'GET' && ['/', '/health', '/openapi.yaml', '/docs'].includes(path)) || (method === 'POST' && path === '/api/payments/webhook');",
          "if (!isPublic && token) {",
          "  pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + token });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Public",
      "auth": { "type": "noauth" },
      "item": [
        {
          "name": "GET /",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] }
          }
        },
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        },
        {
          "name": "GET /openapi.yaml",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/openapi.yaml", "host": ["{{baseUrl}}"], "path": ["openapi.yaml"] }
          }
        },
        {
          "name": "GET /docs",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/docs", "host": ["{{baseUrl}}"], "path": ["docs"] }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/register",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"secret\",\n  \"role\": \"client\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/register", "host": ["{{baseUrl}}"], "path": ["api","register"] }
          }
        },
        {
          "name": "POST /api/login",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"secret\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/login", "host": ["{{baseUrl}}"], "path": ["api","login"] }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "POST /api/orders",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickupAddress\": \"123 A St\",\n  \"dropoffAddress\": \"789 B Ave\",\n  \"price\": 25.5\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api","orders"] }
          }
        },
        {
          "name": "GET /api/orders",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api","orders"],
              "query": [ { "key": "status", "value": "created", "disabled": true } ]
            }
          }
        },
        {
          "name": "PATCH /api/orders/:id",
          "request": {
            "method": "PATCH",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"cancelled\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api","orders",":id"],
              "variable": [ { "key": "id", "value": "{{orderId}}" } ]
            }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "POST /api/payments",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": {{orderId}},\n  \"provider\": \"mock\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/payments", "host": ["{{baseUrl}}"], "path": ["api","payments"] }
          }
        },
        {
          "name": "POST /api/payments/webhook",
          "auth": { "type": "noauth" },
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider\": \"mock\",\n  \"providerPaymentId\": \"mock_123\",\n  \"status\": \"succeeded\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/payments/webhook", "host": ["{{baseUrl}}"], "path": ["api","payments","webhook"] }
          }
        }
      ]
    }
  ]
}
